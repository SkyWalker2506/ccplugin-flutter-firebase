{
  "cds_version": "1.0",
  "name": "ccplugin-flutter-firebase",
  "type": "plugin",
  "input_patterns": [
    {
      "type": "auto_trigger",
      "keywords": [
        "flutter",
        "firebase",
        "dart",
        "widget"
      ],
      "confirm": false,
      "cooldown": 0
    }
  ],
  "output_patterns": [
    {
      "type": "terminal_text",
      "max_lines": 20
    },
    {
      "type": "file_generation",
      "path": "lib/ dart files, firebase config"
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [
        "flutter",
        "dart"
      ],
      "required_secrets": [
        "FIREBASE_SERVICE_ACCOUNT_PATH"
      ],
      "required_mcp": [
        "firebase",
        "flutter-dev"
      ]
    }
  },
  "error_handling": {
    "retry_network": true,
    "max_retries": 3
  }
}
